{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "size": "Large",
      "weight": "Bolder",
      "text": "PIM Activation — Recommendation"
    },
    {
      "type": "TextBlock",
      "spacing": "None",
      "isSubtle": true,
      "wrap": true,
      "text": "Generated by SRE Agent. Human approval still required in the PIM portal."
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Requester", "value": "${requester.displayName} (${requester.upn})" },
        { "title": "Role", "value": "${request.roleDisplayName}" },
        { "title": "Scope", "value": "${request.scope}" },
        { "title": "Duration", "value": "${request.durationHours} hours" },
        { "title": "Justification", "value": "${request.justificationRedacted}" },
        { "title": "Linked ticket", "value": "${ticket.key} — ${ticket.status}" }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "weight": "Bolder",
          "text": "Validation checklist"
        },
        {
          "type": "TextBlock",
          "wrap": true,
          "text": "${checklistMarkdown}"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "style": "${verdictStyle}",
      "items": [
        {
          "type": "TextBlock",
          "size": "Large",
          "weight": "Bolder",
          "text": "Verdict: ${verdict}"
        },
        {
          "type": "TextBlock",
          "spacing": "None",
          "text": "Confidence: ${confidence}  ·  Recommended action: ${recommendedAction}"
        },
        {
          "type": "TextBlock",
          "wrap": true,
          "isSubtle": true,
          "text": "${rationale}"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open in PIM Portal",
      "url": "${links.pimPortal}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "View Ticket",
      "url": "${links.ticket}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "View Evidence",
      "url": "${links.evidence}"
    }
  ]
}
