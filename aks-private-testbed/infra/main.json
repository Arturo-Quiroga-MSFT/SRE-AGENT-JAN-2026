              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.Network/virtualNetworks', format('{0}{1}', variables('abbrs').virtualNetworks, parameters('resourceToken')))]",
              "name": "[guid(resourceId('Microsoft.Network/virtualNetworks', format('{0}{1}', variables('abbrs').virtualNetworks, parameters('resourceToken'))), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}aks-{1}', variables('abbrs').managedIdentities, parameters('resourceToken'))), 'NetworkContributor')]",
              "properties": {
