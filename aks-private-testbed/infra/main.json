            {
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-03-15-preview",
              "name": "[format('alert-pod-restarts-{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "description": "Grocery API pods restarted more than 3 times in 15 minutes — likely CrashLoopBackOff",
                "severity": 1,
                "enabled": true,
                "scopes": [
                  "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}{1}', variables('abbrs').logAnalyticsWorkspaces, parameters('resourceToken')))]"
                ],
                "evaluationFrequency": "PT5M",
                "windowSize": "PT15M",
                "criteria": {
                  "allOf": [
                    {
                      "query": "            KubePodInventory\n            | where Namespace == \"grocery\"\n            | where isnotempty(PodRestartCount)\n            | summarize MaxRestarts = max(toint(PodRestartCount)) by Name, Namespace\n            | where MaxRestarts > 3\n          ",
                      "timeAggregation": "Maximum",
                      "threshold": 3,
                      "operator": "GreaterThan",
                      "metricMeasureColumn": "MaxRestarts",
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                      }
                    }
                  ]
                },
                "autoMitigate": true,
                "actions": {
                  "actionGroups": []
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}{1}', variables('abbrs').logAnalyticsWorkspaces, parameters('resourceToken')))]"
              ]
