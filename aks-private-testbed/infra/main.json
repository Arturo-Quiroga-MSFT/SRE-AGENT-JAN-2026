              "type": "Microsoft.Insights/metricAlerts",
              "apiVersion": "2018-03-01",
              "name": "[format('alert-node-cpu-{0}', parameters('resourceToken'))]",
              "location": "global",
              "tags": "[parameters('tags')]",
              "properties": {
                "description": "AKS node CPU utilization exceeds 80% — investigate workload pressure",
                "severity": 2,
                "enabled": true,
                "scopes": [
                  "[resourceId('Microsoft.ContainerService/managedClusters', format('{0}{1}', variables('abbrs').managedClusters, parameters('resourceToken')))]"
                ],
                "evaluationFrequency": "PT1M",
                "windowSize": "PT5M",
                "criteria": {
                  "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
                  "allOf": [
                    {
                      "name": "HighNodeCPU",
                      "metricName": "node_cpu_usage_percentage",
                      "metricNamespace": "Microsoft.ContainerService/managedClusters",
                      "operator": "GreaterThan",
                      "threshold": 80,
                      "timeAggregation": "Average",
                      "criterionType": "StaticThresholdCriterion"
                    }
                  ]
                },
                "autoMitigate": true,
                "actions": []
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerService/managedClusters', format('{0}{1}', variables('abbrs').managedClusters, parameters('resourceToken')))]"
              ]
            },
            {
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-03-15-preview",
              "name": "[format('alert-no-ready-pods-{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "description": "No ready pods in the grocery namespace — potential full service outage",
                "severity": 0,
                "enabled": true,
                "scopes": [
                  "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}{1}', variables('abbrs').logAnalyticsWorkspaces, parameters('resourceToken')))]"
                ],
                "evaluationFrequency": "PT5M",
                "windowSize": "PT15M",
                "criteria": {
                  "allOf": [
                    {
                      "query": "            KubePodInventory\n            | where Namespace == \"grocery\"\n            | where PodStatus == \"Running\"\n            | summarize ReadyPods = count() by bin(TimeGenerated, 5m)\n          ",
                      "timeAggregation": "Minimum",
                      "threshold": 1,
                      "operator": "LessThan",
                      "metricMeasureColumn": "ReadyPods",
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 2,
                        "minFailingPeriodsToAlert": 2
                      }
                    }
                  ]
                },
                "autoMitigate": true,
                "actions": {
                  "actionGroups": []
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', format('{0}{1}', variables('abbrs').logAnalyticsWorkspaces, parameters('resourceToken')))]"
              ]
            }
