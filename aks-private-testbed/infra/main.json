                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}aks-{1}', variables('abbrs').managedIdentities, parameters('resourceToken'))), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
              },
