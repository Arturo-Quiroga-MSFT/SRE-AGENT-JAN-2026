          },
          "variables": {
            "$fxv#0": {
              "resourcesResourceGroups": "rg-",
              "managedClusters": "aks-",
              "containerRegistries": "acr",
              "logAnalyticsWorkspaces": "log-",
              "managedIdentities": "id-",
              "virtualNetworks": "vnet-",
              "networkSecurityGroups": "nsg-",
